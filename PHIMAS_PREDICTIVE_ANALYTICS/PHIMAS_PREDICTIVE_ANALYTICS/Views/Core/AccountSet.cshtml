@model User
@{
    Layout = "~/Views/Shared/_CoreLayout.cshtml";
    ViewData["Title"] = "Account Settings";
}

<div class="page-grid-2">
    <div class="surface-card p-4">
        <h3 class="section-title">CHO Profile Settings</h3>
        <p class="section-subtitle">Update your account details in the shared user table.</p>
        <form asp-action="AccountSet" asp-controller="CHO" method="post" class="form-grid">
            <input asp-for="UserID" type="hidden" />
            <div>
                <label class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" />
            </div>
            <div>
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div>
                <label class="form-label">Contact Number</label>
                <input asp-for="ContactNumber" class="form-control" />
            </div>
            <div>
                <label class="form-label">Assigned Area</label>
                <input asp-for="AssignedArea" class="form-control" />
            </div>
            <div class="full-width">
                <label class="form-label">New Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Leave blank to keep current password" />
            </div>
            <div class="full-width">
                <button class="btn btn-success" type="submit">Update Account</button>
            </div>
        </form>
    </div>

    <div class="surface-card p-4">
        <h3 class="section-title">Current Account Snapshot</h3>
        <div class="stack-list">
            <div class="stack-item">
                <h4>@Model.FullName</h4>
                <p>@Model.Email</p>
            </div>
            <div class="stack-item">
                <h4>Role</h4>
                <p>@Model.Role</p>
            </div>
            <div class="stack-item">
                <h4>Assigned Area</h4>
                <p>@(string.IsNullOrWhiteSpace(Model.AssignedArea) ? "Not set" : Model.AssignedArea)</p>
            </div>
        </div>
    </div>
</div>
