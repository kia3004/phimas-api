@model PHIMAS_PREDICTIVE_ANALYTICS.Models.Household
@{
    Layout = "~/Views/Shared/_CoreLayout.cshtml";
}

<h2>Add Household</h2>
<form asp-action="AddHousehold" method="post" class="form">
    <div class="mb-3">
        <label asp-for="HouseholdMember"></label>
        <input asp-for="HouseholdMember" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Address"></label>
        <input asp-for="Address" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="NumberOfMembers"></label>
        <input asp-for="NumberOfMembers" class="form-control" type="number" />
    </div>
    <div class="mb-3">
        <label asp-for="RiskScore"></label>
        <input asp-for="RiskScore" class="form-control" type="number" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>