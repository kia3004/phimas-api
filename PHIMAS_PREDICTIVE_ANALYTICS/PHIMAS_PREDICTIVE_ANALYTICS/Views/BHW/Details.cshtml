@{
    Layout = "~/Views/Shared/_BHWLayout.cshtml";
}

<div class="container-fluid" style="padding:20px; font-family: 'Segoe UI', Arial, sans-serif; background-color: #f0fdf4; min-height: 100vh;">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold mb-0" style="color: #1a3c34;">Visit Details</h4>
            <small class="text-muted"><i class="bi bi-clock me-1"></i> Scheduled for Today</small>
        </div>
        <span class="badge rounded-pill bg-white text-dark border px-3 py-1 fw-bold" style="font-size: 0.75rem;">HH-2024-0891</span>
    </div>

    <!-- Household Info Card -->
    <div class="card border-0 shadow-sm mb-3" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="rounded-circle overflow-hidden d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background-color: #d8f3dc;">
                    <i class="bi bi-people-fill" style="color: #2d6a4f; font-size: 1.8rem;"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1" style="color: #1e293b;">Dela Cruz Family</h5>
                    <div class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i> Block 12, Lot 5, Barangay San Jose</div>
                    <div class="text-muted small"><i class="bi bi-telephone me-1"></i> +63 917 123 4567</div>
                </div>
            </div>

            <div class="row g-0 border-top mt-2">
                <div class="col-6 border-end py-2 text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-people" style="color: #2d6a4f;"></i>
                        <span class="fw-bold small">5 Members</span>
                    </div>
                </div>
                <div class="col-6 py-2 text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-calendar-check" style="color: #2d6a4f;"></i>
                        <span class="fw-bold small">Last: 2024-05-15</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Household Risk Status -->
    <div class="card border-0 mb-3" style="border-radius: 12px; background-color: #fff1f2; border: 1px solid #fecdd3 !important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="text-uppercase fw-bold text-muted" style="font-size: 0.65rem; letter-spacing: 0.5px;">Household Risk Status</div>
                <span class="badge rounded-pill bg-danger px-2 py-1 fw-bold" style="font-size: 0.6rem;">High</span>
            </div>
            <div class="d-flex align-items-start gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; background-color: #ffe4e6; flex-shrink: 0;">
                    <i class="bi bi-shield-exclamation text-danger fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-1">Risk Score: 88/100</h6>
                    <p class="text-muted mb-0" style="font-size: 0.75rem; line-height: 1.4;">
                        Immediate attention required due to reported symptoms and historical disease trends in this block.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Objective -->
    <div class="card border-0 mb-3" style="border-radius: 12px; background-color: #f8fafc;">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-info-circle text-muted" style="font-size: 0.9rem;"></i>
                <span class="fw-bold small" style="color: #475569;">Today's Objective</span>
            </div>
            <p class="mb-0 text-secondary" style="font-size: 0.8rem; font-style: italic;">
                "Weekly Health Monitoring - Post-Outbreak Area"
            </p>
        </div>
    </div>

    <!-- Recent Health History Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-activity text-primary me-2"></i>Recent Health History</h6>
        <a href="#" class="fw-bold" style="font-size: 0.75rem; color: #064e3b; text-decoration: none;">View All History <i class="bi bi-chevron-right"></i></a>
    </div>

    <!-- Timeline -->
    <div class="position-relative ps-4 mb-4">
        <div class="position-absolute start-0 top-0 bottom-0 border-start" style="border-width: 2px !important; border-color: #e2e8f0;"></div>

        <!-- Timeline Item 1 -->
        <div class="mb-4 position-relative">
            <div class="position-absolute start-0 translate-middle-x rounded-circle bg-white border border-primary" style="width: 12px; height: 12px; left: -14px; top: 12px;"></div>
            <div class="card border-0 shadow-sm" style="border-radius: 10px;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <small class="text-muted fw-bold">MAY 15, 2024</small>
                        <span class="badge bg-danger rounded-pill" style="font-size: 0.6rem;">Symptoms Detected</span>
                    </div>
                    <h6 class="fw-bold mb-1" style="font-size: 0.85rem;">Fever Check</h6>
                    <p class="text-muted mb-0" style="font-size: 0.75rem;">Two children reported mild fever (38.2°C). Advised isolation.</p>
                </div>
            </div>
        </div>

        <!-- Timeline Item 2 -->
        <div class="mb-4 position-relative">
            <div class="position-absolute start-0 translate-middle-x rounded-circle bg-white border border-secondary" style="width: 12px; height: 12px; left: -14px; top: 12px;"></div>
            <div class="card border-0 shadow-sm" style="border-radius: 10px;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <small class="text-muted fw-bold">MAY 08, 2024</small>
                        <span class="badge bg-light text-dark border rounded-pill" style="font-size: 0.6rem;">Normal</span>
                    </div>
                    <h6 class="fw-bold mb-1" style="font-size: 0.85rem;">Routine Checkup</h6>
                    <p class="text-muted mb-0" style="font-size: 0.75rem;">General wellness check. No symptoms recorded.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Buttons Side by Side -->
    <div class="d-flex gap-2 mb-5">
        <button class="btn fw-bold py-2 w-50 shadow-sm"
                style="border-radius: 10px; background-color: #064e3b; color: #ffffff;">
            <i class="bi bi-check2-circle me-2"></i> Mark Task Completed
        </button>

        <a asp-controller="BHW"
           asp-action="HealthRecords"
           class="btn fw-bold py-2 w-50 text-white"
           style="border-radius: 10px; background-color: #064e3b; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-plus-circle me-2"></i> Add Health Record
        </a>
    </div>

</div>