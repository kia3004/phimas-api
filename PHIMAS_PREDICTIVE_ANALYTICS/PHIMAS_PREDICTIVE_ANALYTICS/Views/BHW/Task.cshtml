@model List<TaskListItemViewModel>
@{
    Layout = "~/Views/Shared/_BHWLayout.cshtml";
    ViewData["Title"] = "Task List";
}

<div class="table-shell">
    <div class="toolbar">
        <div>
            <h3 class="section-title">Assigned Tasks</h3>
            <p class="section-subtitle">These tasks are synchronized with the BHW mobile app through the shared API.</p>
        </div>
    </div>
    <div class="stack-list">
        @foreach (var task in Model)
        {
            <div class="stack-item">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div>
                        <h4>@task.Title</h4>
                        <p>@task.Description</p>
                        <small class="text-secondary">@task.HouseholdName • @task.HouseholdAddress</small>
                    </div>
                    <div class="d-flex flex-column align-items-end gap-2">
                        <span class="status-pill @(task.Priority.ToLower())">@task.Priority</span>
                        <span class="status-pill @(task.Status == "Done" ? "done" : task.Priority.ToLower())">@task.Status</span>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-secondary">@task.TaskDate:g</small>
                    <form asp-action="UpdateTaskStatus" method="post" class="d-flex gap-2">
                        <input type="hidden" name="taskId" value="@task.TaskID" />
                        <select class="form-select" name="status">
                            <option value="Pending" selected="@(task.Status == "Pending" ? "selected" : null)">Pending</option>
                            <option value="Started" selected="@(task.Status == "Started" ? "selected" : null)">Started</option>
                            <option value="Ongoing" selected="@(task.Status == "Ongoing" ? "selected" : null)">Ongoing</option>
                            <option value="Done" selected="@(task.Status == "Done" ? "selected" : null)">Done</option>
                        </select>
                        <button class="btn btn-success" type="submit">Update</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
