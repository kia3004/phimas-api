@model PHIMAS_PREDICTIVE_ANALYTICS.Models.User
@{
    ViewData["Title"] = "Sign In";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .form-container {
        width: 35%;
        margin: 100px auto;
    }
</style>

<div class="form-container">
    <h2 class="text-success text-center mb-4">Login</h2>

    <div class="card p-4 shadow">
        <form method="post" asp-action="SignIn" asp-controller="Account">
            <div asp-validation-summary="All" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label for="email">Email</label>
                <input name="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-3">
                <label asp-for="Role"></label>
                <select asp-for="Role" class="form-control">
                    <option value="CHO">City Health Office</option>
                    <option value="BHW">Barangay Health Workers</option>
                    <option value="ADMIN">Admins</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>

            <button type="submit" class="btn btn-success w-100">
                Login
            </button>

        </form>
    </div>
</div>