@model User
@{
    ViewData["Title"] = "Sign In";
}

<section class="auth-shell">
    <div class="auth-card auth-card--compact">
        <div class="auth-mark">
            <img src="~/images/LOGOP.png" alt="PHIMAS logo" />
            <span>PHIMAS</span>
        </div>

        <h1 class="auth-title">Sign In</h1>

        <form method="post" asp-action="SignIn" asp-controller="Account" class="auth-form">
            <div asp-validation-summary="All" class="text-danger validation-summary-errors mb-3"></div>

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input name="email" id="email" type="email" class="form-control" placeholder="you@example.com" required />
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-select">
                    <option value="CHO">City Health Office</option>
                    <option value="BHW">Barangay Health Worker</option>
                    <option value="ADMIN">Admin</option>
                </select>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>

            <button type="submit" class="btn btn-phimas w-100">Sign In</button>
        </form>

        <div class="auth-switch">
            <a asp-controller="Account" asp-action="SignUp">Create Account</a>
        </div>
    </div>
</section>
