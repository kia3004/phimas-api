@model User
@{
    ViewData["Title"] = "Sign Up";
}

<section class="auth-shell auth-shell--wide">
    <div class="auth-card">
        <div class="auth-mark">
            <img src="~/images/LOGOP.png" alt="PHIMAS logo" />
            <span>PHIMAS</span>
        </div>

        <h1 class="auth-title">Create Account</h1>

        <form method="post" asp-action="SignUp" asp-controller="Account" class="auth-form">
            <div asp-validation-summary="All" class="text-danger validation-summary-errors mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-select">
                    <option value="CHO">City Health Office</option>
                    <option value="BHW">Barangay Health Worker</option>
                    <option value="ADMIN">Admin</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>

            <div class="mb-4">
                <label asp-for="ContactNumber" class="form-label"></label>
                <input asp-for="ContactNumber" class="form-control" />
            </div>

            <button type="submit" class="btn btn-phimas w-100">Register</button>
        </form>

        <div class="auth-switch">
            <a asp-controller="Account" asp-action="SignIn">Already have an account?</a>
        </div>
    </div>
</section>
