@model User
@{
    ViewData["Title"] = "Sign Up";
}

<section class="auth-view auth-view--wide">
    <h1 class="auth-title">Sign Up</h1>

    <form method="post" asp-action="SignUp" asp-controller="Account" class="auth-form">
        <div asp-validation-summary="All" class="validation-summary-errors"></div>

        <div class="auth-field">
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" autocomplete="name" />
        </div>

        <div class="auth-field">
            <label asp-for="Role" class="form-label"></label>
            <select asp-for="Role" class="form-select">
                <option value="CHO">CHO</option>
                <option value="BHW">BHW</option>
                <option value="ADMIN">Admin</option>
            </select>
        </div>

        <div class="auth-field">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" autocomplete="email" />
        </div>

        <div class="auth-field">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" />
        </div>

        <div class="auth-field">
            <label asp-for="ContactNumber" class="form-label"></label>
            <input asp-for="ContactNumber" class="form-control" autocomplete="tel" />
        </div>

        <button type="submit" class="btn btn-phimas w-100">Create Account</button>
    </form>
</section>
