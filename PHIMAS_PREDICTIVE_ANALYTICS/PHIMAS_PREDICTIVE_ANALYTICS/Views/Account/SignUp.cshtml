@model PHIMAS_PREDICTIVE_ANALYTICS.Models.User
@{
    ViewData["Title"] = "Sign Up";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .form-container {
        width: 35%;
        margin: 60px auto;
    }
</style>

<div class="form-container">
    <h2 class="text-success text-center mb-4">Create Account</h2>

    <div class="card p-4 shadow">
        <form method="post" asp-action="SignUp" asp-controller="Account">

            <div class="mb-3">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Role"></label>
                <select asp-for="Role" class="form-control">
                    <option value="CHO">City Health Office</option>
                    <option value="BHW">Barangay Health Workers</option>
                    <option value="ADMIN">Admins</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" />
            </div>

            <div class="mb-3">
                <label asp-for="ContactNumber"></label>
                <input asp-for="ContactNumber" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success w-100">
                Register
            </button>

        </form>
    </div>
</div>
