@model ReportsPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Reports";
}

<div class="section-grid">
    <div class="toolbar">
        <form method="get" asp-action="Reports" asp-controller="Admin">
            <input class="form-control" type="text" name="search" value="@Model.Search" placeholder="Search report title, content, patient, emergency contact, or household" />
            <button class="btn btn-outline-success" type="submit">Search</button>
        </form>
        @if (TempData["Message"] is string message)
        {
            <span class="text-success">@message</span>
        }
        @if (TempData["Error"] is string error)
        {
            <span class="text-danger">@error</span>
        }
    </div>

    <section class="metric-grid">
        <article class="metric-card accent-green">
            <small>Total Scope</small>
            <h3>@Model.TotalScope</h3>
            <p>Households currently represented in the database.</p>
        </article>
        <article class="metric-card accent-amber">
            <small>Data Points</small>
            <h3>@Model.DataPoints</h3>
            <p>Health records contributing to reporting and forecasting.</p>
        </article>
        <article class="metric-card accent-red">
            <small>Risk Index</small>
            <h3>@Model.RiskIndex</h3>
            <p>Current aggregate household risk classification.</p>
        </article>
    </section>

    <section class="page-grid-2">
        <div class="form-shell">
            <h3 class="section-title">Add Report</h3>
            <p class="section-subtitle">Admin can create, correct, or remove reports and consultation logs directly.</p>
            <form asp-action="SaveReport" method="post" class="form-grid" autocomplete="off">
                <input asp-for="Form.ReportID" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger full-width"></div>
                <div>
                    <label asp-for="Form.GeneratedBy" class="form-label">Generated By</label>
                    <select asp-for="Form.GeneratedBy" class="form-select" asp-items="@(new SelectList(Model.Users, "UserID", "FullName"))">
                        <option value="">Select user</option>
                    </select>
                    <span asp-validation-for="Form.GeneratedBy" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Form.DateGenerated" class="form-label">Date</label>
                    <input asp-for="Form.DateGenerated" type="date" class="form-control" />
                    <span asp-validation-for="Form.DateGenerated" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Form.PatientName" class="form-label">Patient Name</label>
                    <input asp-for="Form.PatientName" class="form-control" placeholder="Enter patient name" />
                    <span asp-validation-for="Form.PatientName" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Form.ContactNumber" class="form-label">Contact Number</label>
                    <input asp-for="Form.ContactNumber" class="form-control" placeholder="09XXXXXXXXX" />
                    <span asp-validation-for="Form.ContactNumber" class="text-danger"></span>
                </div>
                <div class="full-width">
                    <label asp-for="Form.Address" class="form-label">Household Address</label>
                    <textarea asp-for="Form.Address" rows="3" class="form-control"></textarea>
                    <span asp-validation-for="Form.Address" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Form.EmergencyContactName" class="form-label">Emergency Contact Name</label>
                    <input asp-for="Form.EmergencyContactName" class="form-control" />
                    <span asp-validation-for="Form.EmergencyContactName" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Form.EmergencyContactNumber" class="form-label">Emergency Contact Number</label>
                    <input asp-for="Form.EmergencyContactNumber" class="form-control" />
                    <span asp-validation-for="Form.EmergencyContactNumber" class="text-danger"></span>
                </div>
                <div class="full-width">
                    <label asp-for="Form.ReportType" class="form-label">Report Type</label>
                    <input asp-for="Form.ReportType" class="form-control" />
                    <span asp-validation-for="Form.ReportType" class="text-danger"></span>
                </div>
                <div class="full-width">
                    <label asp-for="Form.Content" class="form-label">Content</label>
                    <textarea asp-for="Form.Content" rows="6" class="form-control"></textarea>
                    <span asp-validation-for="Form.Content" class="text-danger"></span>
                </div>
                <div class="full-width">
                    <button class="btn btn-success" type="submit">Save Report</button>
                </div>
            </form>
        </div>

        <div class="surface-card p-4">
            <h3 class="section-title">AI Assistant Insights</h3>
            <p class="section-subtitle">Insights remain visible while admin updates the shared reporting data set.</p>
            <div class="insight-list">
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4>@insight.Title</h4>
                            <span class="severity-pill @insight.Severity.ToLower()">@insight.Severity</span>
                        </div>
                        <p>@insight.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <div class="table-shell">
        <h3 class="section-title">Saved Reports</h3>
        <p class="section-subtitle">Deletes remove the report row from the database and the report disappears from this list on the next load.</p>
        <div class="stack-list">
            @if (!Model.Reports.Any())
            {
                <div class="stack-item">
                    <p class="mb-0 text-secondary">No reports found.</p>
                </div>
            }
            else
            {
                @foreach (var report in Model.Reports)
                {
                    <div class="stack-item">
                        <form asp-action="SaveReport" method="post" class="form-grid" autocomplete="off">
                            <input type="hidden" name="Form.ReportID" value="@report.ReportID" />
                            <div>
                                <label class="form-label">Generated By</label>
                                <select class="form-select" name="Form.GeneratedBy">
                                    <option value="">Select user</option>
                                    @foreach (var user in Model.Users)
                                    {
                                        <option value="@user.UserID" selected="@(report.GeneratedBy == user.UserID ? "selected" : null)">@user.FullName</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Date</label>
                                <input class="form-control" type="date" name="Form.DateGenerated" value="@report.DateGenerated.ToString("yyyy-MM-dd")" />
                            </div>
                            <div>
                                <label class="form-label">Patient Name</label>
                                <input class="form-control" name="Form.PatientName" value="@report.DisplayPatientName" />
                            </div>
                            <div>
                                <label class="form-label">Contact Number</label>
                                <input class="form-control" name="Form.ContactNumber" value="@report.Patient?.ContactNumber" />
                            </div>
                            <div class="full-width">
                                <label class="form-label">Household Address</label>
                                <textarea class="form-control" name="Form.Address" rows="3">@report.DisplayAddress</textarea>
                            </div>
                            <div>
                                <label class="form-label">Emergency Contact Name</label>
                                <input class="form-control" name="Form.EmergencyContactName" value="@report.DisplayEmergencyContactName" />
                            </div>
                            <div>
                                <label class="form-label">Emergency Contact Number</label>
                                <input class="form-control" name="Form.EmergencyContactNumber" value="@report.DisplayEmergencyContactNumber" />
                            </div>
                            <div class="full-width">
                                <label class="form-label">Report Type</label>
                                <input class="form-control" name="Form.ReportType" value="@report.ReportType" />
                            </div>
                            <div class="full-width">
                                <label class="form-label">Content</label>
                                <textarea class="form-control" name="Form.Content" rows="5">@report.DisplayContent</textarea>
                            </div>
                            <div class="full-width d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <small class="text-secondary">Generated @report.DateGenerated.ToString("g")</small>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-success" type="submit">Update</button>
                                    <button class="btn btn-outline-danger" type="submit" formaction="@Url.Action("DeleteReport", "Admin", new { id = report.ReportID })" formmethod="post">Delete</button>
                                </div>
                            </div>
                        </form>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
