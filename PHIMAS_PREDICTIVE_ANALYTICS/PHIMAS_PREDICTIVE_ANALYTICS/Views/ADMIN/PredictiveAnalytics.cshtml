@using System.Text.Json
@model PredictiveAnalyticsPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Predictive Analytics";
    var chartJson = JsonSerializer.Serialize(Model.DiseaseTrend);
}

<div class="section-grid">
    <section class="page-grid-2">
        <div class="surface-card chart-card">
            <h3 class="section-title">Disease Trend Forecast Window</h3>
            <p class="section-subtitle">Historical health records transformed into a short-horizon prediction curve.</p>
            <canvas id="predictiveTrendChart"></canvas>
        </div>

        <div class="surface-card p-4">
            <h3 class="section-title">Latest Prediction Snapshot</h3>
            <p class="section-subtitle">The most recent predictive analysis stored in the database.</p>
            @if (Model.LatestAnalysis != null)
            {
                <div class="stack-item">
                    <h4>@Model.LatestAnalysis.Disease</h4>
                    <p>@Model.LatestAnalysis.PredictedCases projected cases in @Model.LatestAnalysis.HighRiskBarangay.</p>
                    <span class="severity-pill @(Model.LatestAnalysis.ConfidenceScore >= 0.8f ? "high" : "medium")">@($"{Model.LatestAnalysis.ConfidenceScore:P0}")</span>
                </div>
            }
            else
            {
                <div class="stack-item">
                    <p class="mb-0 text-secondary">No saved predictive-module analysis is available yet.</p>
                </div>
            }
        </div>
    </section>

    <section class="page-grid-2">
        <div class="surface-card p-4">
            <h3 class="section-title">Forecast Queue</h3>
            <p class="section-subtitle">Current disease projections shown to admins, with stored predictive results preferred.</p>
            <div class="stack-list">
                @if (!Model.Forecasts.Any())
                {
                    <div class="stack-item">
                        <p class="mb-0 text-secondary">No saved forecasts are available yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var forecast in Model.Forecasts)
                    {
                        <div class="stack-item">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h4>@forecast.Disease</h4>
                                <span class="severity-pill @(forecast.ConfidenceScore >= 0.8f ? "high" : "medium")">@($"{forecast.ConfidenceScore:P0}")</span>
                            </div>
                            <p>@forecast.CurrentCases current cases, @forecast.PredictedCases projected cases, focus on @forecast.HighRiskBarangay.</p>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="surface-card p-4">
            <h3 class="section-title">AI Assistant</h3>
            <p class="section-subtitle">Narrative insights derived from the same predictive dataset.</p>
            <div class="insight-list">
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4>@insight.Title</h4>
                            <span class="severity-pill @insight.Severity.ToLower()">@insight.Severity</span>
                        </div>
                        <p>@insight.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const predictiveTrend = @Html.Raw(chartJson);
        new Chart(document.getElementById("predictiveTrendChart"), {
            type: "line",
            data: {
                labels: predictiveTrend.map(item => item.label),
                datasets: [{
                    label: "Recorded cases",
                    data: predictiveTrend.map(item => item.value),
                    borderColor: "#5a53d8",
                    backgroundColor: "rgba(90, 83, 216, 0.15)",
                    fill: true,
                    tension: 0.35
                }]
            }
        });
    </script>
}
