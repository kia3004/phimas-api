@using System.Text.Json
@model PredictiveAnalyticsPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Predictive Analytics";
    var chartJson = JsonSerializer.Serialize(Model.DiseaseTrend);
    var barangayChartJson = JsonSerializer.Serialize(Model.HighRiskBarangayTrend);
}

<div class="section-grid">
    <section class="page-grid-2">
        <div class="surface-card chart-card">
            <h3 class="section-title">Disease Trend Forecast Window</h3>
            <p class="section-subtitle">Historical health records transformed into a short-horizon prediction curve.</p>
            <canvas id="predictiveTrendChart"></canvas>
        </div>

        <div class="surface-card chart-card">
            <h3 class="section-title">High-Risk Barangays (Predicted)</h3>
            <p class="section-subtitle">
                Top 5 barangays grouped from the latest predictive-analysis batch
                @if (Model.HighRiskBarangaySnapshot.LatestPredictionDate.HasValue)
                {
                    <text>(@Model.HighRiskBarangaySnapshot.LatestPredictionDate.Value.ToString("MMM dd, yyyy")).</text>
                }
                else
                {
                    <text>.</text>
                }
            </p>
            <canvas id="adminBarangayRiskChart"></canvas>
        </div>
    </section>

    <section class="page-grid-2">
        <div class="surface-card p-4">
            <h3 class="section-title">Latest Prediction Snapshot</h3>
            <p class="section-subtitle">Aggregated directly from `predictive_analysis` by barangay.</p>
            <div class="stack-list">
                @if (!Model.HighRiskBarangaySnapshot.Barangays.Any())
                {
                    <div class="stack-item">
                        <p class="mb-0 text-secondary">No saved predictive-analysis data is available yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var barangay in Model.HighRiskBarangaySnapshot.Barangays)
                    {
                        <div class="stack-item">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h4>@barangay.Barangay</h4>
                                <span class="severity-pill high">@barangay.TotalCases cases</span>
                            </div>
                            <p>@barangay.TotalCases total predicted cases across @barangay.PredictionEntries forecast entries.</p>
                            <small class="text-secondary">Latest generated: @barangay.LatestGenerated.ToString("MMM dd, yyyy")</small>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="surface-card p-4">
            <h3 class="section-title">AI Assistant</h3>
            <p class="section-subtitle">Narrative insights derived from the same predictive dataset.</p>
            <div class="insight-list">
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4>@insight.Title</h4>
                            <span class="severity-pill @insight.Severity.ToLower()">@insight.Severity</span>
                        </div>
                        <p>@insight.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const predictiveTrend = @Html.Raw(chartJson);
        const barangayTrend = @Html.Raw(barangayChartJson);
        new Chart(document.getElementById("predictiveTrendChart"), {
            type: "line",
            data: {
                labels: predictiveTrend.map(item => item.Label),
                datasets: [{
                    label: "Recorded cases",
                    data: predictiveTrend.map(item => item.Value),
                    borderColor: "#5a53d8",
                    backgroundColor: "rgba(90, 83, 216, 0.15)",
                    fill: true,
                    tension: 0.35
                }]
            }
        });

        new Chart(document.getElementById("adminBarangayRiskChart"), {
            type: "bar",
            data: {
                labels: barangayTrend.map(item => item.Label),
                datasets: [{
                    label: "Predicted Cases",
                    data: barangayTrend.map(item => item.Value),
                    backgroundColor: "rgba(214, 167, 44, 0.72)"
                }]
            },
            options: {
                indexAxis: "y"
            }
        });
    </script>
}
