@model AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="section-grid">
    <section class="metric-grid">
        @foreach (var card in Model.Cards)
        {
            <article class="metric-card @card.AccentClass">
                <small>@card.Label</small>
                <h3>@card.Value</h3>
                <p>@card.Subtitle</p>
            </article>
        }
    </section>

    <section class="page-grid-2">
        <div class="section-grid">
            <div class="table-shell">
                <div class="toolbar">
                    <div>
                        <h3 class="section-title">Recent Field Tasks</h3>
                        <p class="section-subtitle">Live assignments and their current status.</p>
                    </div>
                    <a class="btn btn-success" asp-controller="Admin" asp-action="TaskMonitoring">Open Task Monitoring</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Household</th>
                                <th>BHW</th>
                                <th>Priority</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.RecentTasks)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@task.Title</div>
                                        <small class="text-secondary">@task.TaskDate:g</small>
                                    </td>
                                    <td>@task.HouseholdName</td>
                                    <td>@task.BHWName</td>
                                    <td><span class="status-pill @(task.Priority.ToLower())">@task.Priority</span></td>
                                    <td><span class="status-pill @(task.Status == "Done" ? "done" : task.Priority.ToLower())">@task.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="table-shell">
                <div class="toolbar">
                    <div>
                        <h3 class="section-title">Recent Reports</h3>
                        <p class="section-subtitle">Automated and manual reports saved to the shared database.</p>
                    </div>
                    <a class="btn btn-outline-success" asp-controller="Admin" asp-action="Reports">Manage Reports</a>
                </div>
                <div class="stack-list">
                    @foreach (var report in Model.RecentReports)
                    {
                        <div class="stack-item">
                            <h4>@report.ReportType</h4>
                            <p>@report.Content</p>
                            <small class="text-secondary">@report.DateGenerated:g</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="section-grid">
            <div class="surface-card p-4">
                <h3 class="section-title">AI Assistant Insights</h3>
                <p class="section-subtitle">System-generated summaries, alerts, and recommendations.</p>
                <div class="insight-list">
                    @foreach (var insight in Model.ActivitySummary)
                    {
                        <div class="insight-item">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h4>@insight.Title</h4>
                                <span class="severity-pill @insight.Severity.ToLower()">@insight.Severity</span>
                            </div>
                            <p>@insight.Description</p>
                        </div>
                    }
                </div>
            </div>

            <div class="surface-card p-4">
                <h3 class="section-title">Low Stock Overview</h3>
                <p class="section-subtitle">Items below the configured replenishment threshold.</p>
                <div class="stack-list">
                    @foreach (var item in Model.LowStockItems)
                    {
                        <div class="stack-item">
                            <div class="d-flex justify-content-between">
                                <h4>@item.ItemName</h4>
                                <span class="severity-pill high">Low</span>
                            </div>
                            <p>@(item.CurrentStock ?? 0) @item.Unit available, threshold @(item.MinimumThreshold ?? 0).</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</div>
