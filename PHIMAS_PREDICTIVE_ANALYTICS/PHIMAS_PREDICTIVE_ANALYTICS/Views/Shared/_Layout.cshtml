@{
    var title = ViewData["Title"]?.ToString();
    var pageTitle = string.IsNullOrWhiteSpace(title) || string.Equals(title, "PHIMAS", StringComparison.OrdinalIgnoreCase)
        ? "PHIMAS"
        : $"{title} - PHIMAS";
    var path = Context.Request.Path.Value ?? string.Empty;
    var isHomePage = path.Equals("/", StringComparison.OrdinalIgnoreCase) || path.Equals("/Home", StringComparison.OrdinalIgnoreCase) || path.Equals("/Home/Index", StringComparison.OrdinalIgnoreCase);
    var isStartupPage = isHomePage;
    var isSignInPage = path.Equals("/Account/SignIn", StringComparison.OrdinalIgnoreCase);
    var isSignUpPage = path.Equals("/Account/SignUp", StringComparison.OrdinalIgnoreCase);
    var isAuthPage = isSignInPage || isSignUpPage;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="phimas-public @(isAuthPage ? "phimas-public--auth" : isStartupPage ? "phimas-public--startup" : null)">
    @if (isStartupPage)
    {
        <main class="startup-shell" role="main">
            @RenderBody()
        </main>
    }
    else if (isAuthPage)
    {
        <main class="public-main public-main--auth" role="main">
            <section class="auth-card-shell @(isSignUpPage ? "auth-card-shell--wide" : null)">
                <div class="auth-card">
                    <header class="auth-card__header">
                        <a class="auth-card__brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="PHIMAS home">
                            <img src="~/images/LOGOP.png" alt="PHIMAS logo" />
                        </a>
                    </header>

                    <div class="auth-card__body">
                        @RenderBody()
                    </div>

                    <footer class="auth-card__footer">
                        <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </footer>
                </div>
            </section>
        </main>
    }
    else
    {
        <div class="public-shell">
            <header class="public-header">
                <a class="public-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="PHIMAS home">
                    <span class="public-brand__logos">
                        <img src="~/images/LOGOP.png" alt="PHIMAS logo" />
                        <img src="~/images/citylogo1.png" alt="City logo 1" />
                        <img src="~/images/citylogo2.png" alt="City logo 2" />
                    </span>
                    <span class="public-brand__copy">
                        <strong>PHIMAS</strong>
                        <span>Public Health Information Management and Analytics System</span>
                    </span>
                </a>

                <nav class="public-nav" aria-label="Primary">
                    <a class="public-nav__link @(isHomePage ? "is-active" : null)"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">Home</a>
                    <a class="public-nav__link @(isSignInPage ? "is-active" : null)"
                       asp-controller="Account"
                       asp-action="SignIn">Sign In</a>
                    <a class="public-nav__link public-nav__link--cta @(isSignUpPage ? "is-active" : null)"
                       asp-controller="Account"
                       asp-action="SignUp">Sign Up</a>
                </nav>
            </header>

            <main class="public-main public-main--content" role="main">
                @RenderBody()
            </main>

            <footer class="public-footer">
                <span>PHIMAS</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </footer>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
