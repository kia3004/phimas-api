@{
    var active = ViewData["Active"]?.ToString();
    var title = ViewData["Title"]?.ToString();
    var pageTitle = string.IsNullOrWhiteSpace(title) ? "PHIMAS" : $"{title} - PHIMAS";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <script>document.documentElement.setAttribute("data-theme", localStorage.getItem("phimas-theme") || "light");</script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/phimas.css" asp-append-version="true" />
</head>
<body>
    <div class="phimas-shell">
        <aside class="phimas-sidebar">
            <div class="phimas-brand">
                <img src="~/images/LOGOP.png" alt="PHIMAS logo" />
                <div>
                    <h1>PHIMAS</h1>
                    <p>CHO workspace</p>
                </div>
            </div>

            <nav class="phimas-nav">
                <a class="phimas-nav-link @(active == "Dashboard" ? "is-active" : "")" asp-controller="CHO" asp-action="Dashboard"><span><i class="bi bi-speedometer2"></i></span>Dashboard</a>
                <a class="phimas-nav-link @(active == "Households" ? "is-active" : "")" asp-controller="CHO" asp-action="Households"><span><i class="bi bi-houses-fill"></i></span>Households</a>
                <a class="phimas-nav-link @(active == "HealthRecords" ? "is-active" : "")" asp-controller="CHO" asp-action="HealthRecords"><span><i class="bi bi-heart-pulse-fill"></i></span>Health Records</a>
                <a class="phimas-nav-link @(active == "PredictiveAnalytics" ? "is-active" : "")" asp-controller="CHO" asp-action="PredictiveAnalytics"><span><i class="bi bi-activity"></i></span>Predictive Analytics</a>
                <a class="phimas-nav-link @(active == "TaskMonitoring" ? "is-active" : "")" asp-controller="CHO" asp-action="TaskMonitoring"><span><i class="bi bi-kanban-fill"></i></span>Task Monitoring</a>
                <a class="phimas-nav-link @(active == "Reports" ? "is-active" : "")" asp-controller="CHO" asp-action="Reports"><span><i class="bi bi-file-earmark-bar-graph-fill"></i></span>Reports</a>
                <a class="phimas-nav-link @(active == "AccountSet" ? "is-active" : "")" asp-controller="CHO" asp-action="AccountSet"><span><i class="bi bi-person-circle"></i></span>Account</a>
            </nav>

            <div class="phimas-sidebar-footer">
                <a class="phimas-nav-link" asp-controller="Account" asp-action="SignOut"><span><i class="bi bi-box-arrow-right"></i></span>Sign out</a>
            </div>
        </aside>

        <main class="phimas-main">
            <header class="phimas-header">
                <div>
                    <h2>@(ViewData["Title"] ?? "CHO Dashboard")</h2>
                    <p>Signed in as @(User.Identity?.Name ?? "City Health Officer")</p>
                </div>
                <button type="button" class="theme-switch" data-theme-toggle role="switch" aria-checked="false" aria-label="Toggle color theme">
                    <span class="theme-switch__icon theme-switch__icon--sun" aria-hidden="true"><i class="bi bi-sun-fill"></i></span>
                    <span class="theme-switch__icon theme-switch__icon--moon" aria-hidden="true"><i class="bi bi-moon-stars-fill"></i></span>
                </button>
            </header>

            @RenderBody()
            <p class="footer-note">PHIMAS | Public Health Information Management and Analytics System</p>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
