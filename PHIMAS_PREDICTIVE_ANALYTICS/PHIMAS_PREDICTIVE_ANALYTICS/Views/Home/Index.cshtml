@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>PHIMAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            background: url('@Url.Content("~/images/background.png")') no-repeat center center fixed;
            background-size: cover;
            height: 100vh;
        }

        /* HEADER */
        .main-header {
            background-color: white;
            padding: 10px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .left-logos img {
            height: 100px;
            margin-right: 15px;
        }

        .right-buttons a {
            margin-left: 15px;
            font-weight: bold;
            width: 150px;
            height: 40px;
        }

        /* CUSTOM GREEN BUTTON */
        .btn-green {
            background-color: #66cc99; /* light green */
            color: white;
            border: none;
            transition: 0.3s ease;
        }

            .btn-green:hover {
                background-color: #064d1f; /* dark green */
                color: white;
            }

    </style>
</head>
<body>

    <!-- HEADER -->
    <div class="main-header">

        <!-- LEFT SIDE LOGOS -->
        <div class="left-logos">
            <img src="@Url.Content("~/images/LOGOP.png")" />
            <img src="@Url.Content("~/images/citylogo1.png")" />
            <img src="@Url.Content("~/images/citylogo2.png")" />
        </div>

        <!-- RIGHT SIDE BUTTONS -->
        <div class="right-buttons">
            <a asp-controller="Account" asp-action="SignUp"
               class="btn btn-green">
                Sign Up
            </a>

            <a asp-controller="Account" asp-action="SignIn"
               class="btn btn-green">
                Sign In
            </a>
        </div>

    </div>

</body>
</html>