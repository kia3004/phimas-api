@{
    ViewData["Title"] = "PHIMAS";
}

<section class="public-card home-hero">
    <div class="hero-copy">
        <span class="hero-badge">PHIMAS</span>
        <h1 class="hero-title">A unified workspace for disease monitoring, field coordination, and predictive outbreak insights.</h1>
        <div class="hero-actions">
            <a asp-controller="Account" asp-action="SignIn" class="btn btn-phimas">Sign In</a>
            <a asp-controller="Account" asp-action="SignUp" class="btn btn-ghost">Create Account</a>
        </div>
    </div>

    <div class="hero-panel">
        <div class="hero-panel__item">
            <strong>CHO</strong>
            <span>Review disease trends and predictive analytics.</span>
        </div>
        <div class="hero-panel__item">
            <strong>Admin</strong>
            <span>Manage users, records, inventory, and reports.</span>
        </div>
        <div class="hero-panel__item">
            <strong>BHW</strong>
            <span>Track field tasks and synchronize household health records.</span>
        </div>
    </div>
</section>
